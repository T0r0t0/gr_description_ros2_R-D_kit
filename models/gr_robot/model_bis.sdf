      Wheel definition
      <back_left_joint>left_rear_wheel_joint</back_left_joint>
      <back_right_joint>right_rear_wheel_joint</back_right_joint>
      <front_left_joint>left_front_wheel_joint</front_left_joint>
      <front_right_joint>right_front_wheel_joint</front_right_joint>

      <wheel_separation>0.170</wheel_separation>
