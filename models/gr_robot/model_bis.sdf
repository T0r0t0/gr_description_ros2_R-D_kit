<?xml version="1.0"?>
<sdf version="1.9">
  <model name='gr_robot'>
    <link name='base_link'>

      <inertial>
        <pose>0.00172 0.000157 -0.015991 0 -0 0</pose>
        <mass>62.904</mass>
        <inertia>
          <ixx>5.55936</ixx>
          <ixy>-0.00212481</ixy>
          <ixz>-0.0130841</ixz>
          <iyy>5.70812</iyy>
          <iyz>-0.00151496</iyz>
          <izz>3.74187</izz>
        </inertia>
      </inertial>

      <collision name='base_link_collision'>
        <pose>0 0 0 1.5707 -0 -1.5707</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>file:///ros2_ws/install/gr_description/share/gr_description/meshes/agilex/scout/scout_mini_base_link.dae</uri>
          </mesh>
        </geometry>
        <surface>
          <contact>
            <ode/>
          </contact>
          <friction>
            <ode/>
          </friction>
        </surface>
      </collision>

      <collision name='base_link_fixed_joint_lump__bottom_box_link_collision_5'>
        <pose>0 0 0.069 1.5708 0 -1.5708</pose>
        <geometry>
          <mesh>
            <scale>0.001 0.001 0.001</scale>
            <uri>file:///ros2_ws/install/gr_description/share/gr_description/meshes/accessories/gr_ros_kit_v3.stl</uri>
          </mesh>
        </geometry>
      </collision>

      <collision name='base_link_fixed_joint_lump__imu_link_collision_6'>
        <pose>0 0 0.121 0 -0 0</pose>
        <geometry>
          <box>
            <size>0.01 0.01 0.004</size>
          </box>
        </geometry>
      </collision>

      <visual name='base_link_visual'>
        <pose>0 0 0 1.5707 -0 -1.5707</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>file:///ros2_ws/install/gr_description/share/gr_description/meshes/agilex/scout/scout_mini_base_link.dae</uri>
          </mesh>
        </geometry>
      </visual>
     
      <self_collide>0</self_collide>
      <enable_wind>0</enable_wind>
      <kinematic>0</kinematic>
      <gravity>1</gravity>
    </link>

    <link name="imu_link">
      <visual name='base_link_fixed_joint_lump__bottom_box_link_visual_5'>
        <pose>0 0 0.069 1.5708 0 -1.5708</pose>
        <geometry>
          <mesh>
            <scale>0.001 0.001 0.001</scale>
            <uri>file:///ros2_ws/install/gr_description/share/gr_description/meshes/accessories/gr_ros_kit_v3.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.7 0.7 0.7 1</ambient>  <!-- RGBA -->
          <diffuse>0.2 0.2 0.2 1</diffuse>  <!-- Red color -->
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>

      <visual name='base_link_fixed_joint_lump__imu_link_visual_6'>
        <pose>0 0 0.121 0 -0 0</pose>
        <geometry>
          <box>
            <size>0.01 0.01 0.004</size>
          </box>
        </geometry>
      </visual>


      <sensor name='imu_sensor' type='imu'>
        <topic>/model/gr_robot/imu</topic>
        <ignition_frame_id>imu_link</ignition_frame_id>
        <always_on>1</always_on>
        <update_rate>20</update_rate>
        <visualize>1</visualize>
      </sensor>

      <sensor name='magneto_sensor' type='magnetometer'>
        <topic>/model/gr_robot/magnetometer</topic>
        <always_on>1</always_on>
        <update_rate>20</update_rate>
        <visualize>1</visualize>

        <!-- Magnetometer-specific properties -->
        <magnetometer>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </magnetometer>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
    </joint>
    
    <link name="rslidar">
      <!-- <pose>-0.043 0 0.3273 1.5708 -0 1.5708</pose> -->
    </link>
    <joint name="rslidar_joint" type="fixed">
      <pose>-0.043 0 0.3273 0 -0 0</pose>
      <parent>base_link</parent>
      <child>rslidar</child>
    </joint>

    <link name="RS16_link">
      <visual name='base_link_fixed_joint_lump__base_visual_visual_8'>
        <pose>-0.043 0 0.3273 1.5708 -0 1.5708</pose>
        <geometry>
          <mesh>
            <scale>0.001 0.001 0.001</scale>
            <uri>file:///ros2_ws/install/gr_description/share/gr_description/meshes/accessories/helios_16.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.5 1</ambient>  <!-- RGBA -->
          <diffuse>0.8 0.2 0.2 1</diffuse>  <!-- Red color -->
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual> 

      <collision name='base_link_fixed_joint_lump__base_collision_collision_8'>
        <pose>-0.043 0 0.3893 0 -0 0</pose>
        <geometry>
          <cylinder>
            <length>0.08</length>
            <radius>0.04</radius>
          </cylinder>
        </geometry>
      </collision>

      <sensor name='RS16' type='gpu_lidar'>
        <pose>-0.043 0 0.38548 0 -0 0</pose>
        <update_rate>100</update_rate>
        <topic>/model/gr_robot/lidar</topic>
        <ignition_frame_id>rslidar</ignition_frame_id>
        <!-- <output>points</output> -->

        <ray>
          <scan>
            <horizontal>
              <samples>512</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>16</samples>
              <resolution>1</resolution>
              <min_angle>-0.261799</min_angle>
              <max_angle>0.261799</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.4</min>
            <max>201</max>
            <resolution>0.001</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0</stddev>
          </noise>
        </ray>
        <visualize>false</visualize>
        <always_on>0</always_on>
      </sensor>
    </link>

    <joint name="RS16_joint" type="fixed">
      <parent>base_link</parent>
      <child>RS16_link</child>
      <pose>-0.043 0 0.3893 0 -0 0</pose>
    </joint>

    <link name="camera_link">
      <visual name='base_link_fixed_joint_lump__camera_link_visual_7'>
        <pose>0.2319 0 0.1375 1.5708 -0 1.5708</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>file:///ros2_ws/install/gr_description/share/gr_description/meshes/accessories/d435.dae</uri>
