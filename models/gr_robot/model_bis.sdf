    <link name="left_front_wheel_link">
      <visual name='base_link_fixed_joint_lump__front_left_wheel_link_visual_1'>
        <pose>0.231976 0.208252 -0.100998 1.57 0 3.14</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>file:///ros2_ws/install/gr_description/share/gr_description/meshes/agilex/scout/wheel.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <collision name='base_link_fixed_joint_lump__front_left_wheel_link_collision_1'>
        <pose>0.231976 0.208252 -0.100998 1.57 0 3.14</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>file:///ros2_ws/install/gr_description/share/gr_description/meshes/agilex/scout/wheel.dae</uri>
          </mesh>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>10.0</mu>  <!-- High static friction coefficient -->
              <mu2>10.0</mu2> <!-- Optional: High kinetic friction coefficient -->
            </ode>
          </friction>
          <contact>
            <ode>
              <soft_cfm>0.01</soft_cfm>  <!-- Constraint Force Mixing -->
              <soft_erp>0.8</soft_erp>  <!-- Error Reduction Parameter -->
            </ode>
          </contact>
        </surface>
      </collision>

