    <plugin filename="ignition-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_rear_wheel_joint</left_joint>
      <right_joint>right_rear_wheel_joint</right_joint>
      <wheel_separation>0.416504</wheel_separation>
      <wheel_diameter>0.015</wheel_diameter>

      <!-- <torque>10</torque> -->
      <topic>/model/gr_robot/cmd_vel</topic>


      <odom_publish_frequency>20.0</odom_publish_frequency>
      <update_rate>20.0</update_rate>
      <!-- <tf_frame_prefix_enable>0</tf_frame_prefix_enable> -->

      <publish_odom>false</publish_odom>
      <odom_topic>/odom</odom_topic>


      <publish_odom_tf>true</publish_odom_tf>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>

    </plugin>


    <plugin filename="ignition-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_front_wheel_joint</left_joint>
      <right_joint>right_front_wheel_joint</right_joint>
      <wheel_separation>0.416504</wheel_separation>
      <wheel_diameter>0.015</wheel_diameter>

      <!-- <torque>10</torque> -->
      <topic>/model/gr_robot/cmd_vel</topic>

      <update_rate>20.0</update_rate>
      <publish_odom>0</publish_odom>
      <publish_odom_tf>0</publish_odom_tf>

      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <static>0</static>

  </model>
</sdf>