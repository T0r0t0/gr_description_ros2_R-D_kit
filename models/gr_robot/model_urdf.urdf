  <!-- Lidar Definition -->
  
  <link name="rslidar"/>
  <joint name="rslidar_joint" type="fixed">
    <origin xyz="-0.043 0 0.3273" rpy="0 -0 0"/>
    <parent link="base_link"/>
    <child link="rslidar"/>
  </joint>
  
  <link name="RS16_link">
