      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1" ixy="0.0" ixz="0.0" iyy="1" iyz="0.0" izz="1"/>
    </inertial>
    <gazebo reference="imu_link">
      <gravity>true</gravity>
    </gazebo>
  </link>
  <joint name="_imu_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.0 0.0 0.050"/>
    <parent link="bottom_box_link"/>
    <child link="imu_link"/>
  </joint>
  <!-- <link name="${parent}"/> -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <namespace></namespace>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
        <updateRateHZ>20.0</updateRateHZ>
      </plugin>
      <always_on>true</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
    </sensor>
  </gazebo>
  <!-- Electrical Box -->
  <link name="gps_antenna_link">
    <!-- <visual>
        <origin xyz="0 0 0.0278" rpy="0 0 0" />
        <geometry>
            <cylinder radius="0.01375" length="0.0556"/>
        </geometry>
        <material name="DarkGrey">
          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>
      <collision>
      <origin xyz="0 0 0.0278" rpy="0 0 0" />
         <geometry>
            <cylinder radius="0.01375" length="0.0556"/>
        </geometry>
      </collision> -->
  </link>
  <joint name="gps_antenna_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.164 0.0 0.0"/>
    <parent link="top_box_link"/>
    <child link="gps_antenna_link"/>
  </joint>
  <!-- <link name="${parent}"/> -->
  <gazebo reference="gps_antenna_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
</robot>
