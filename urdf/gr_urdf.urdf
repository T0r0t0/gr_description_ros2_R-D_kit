        <topicname>/rslidar_points</topicname>
        <frameName>rslidar</frameName>
        <min_range>0.2</min_range>
        <max_range>200.0</max_range>
        <gaussianNoise>0.008</gaussianNoise>
      </plugin>
    </sensor>
