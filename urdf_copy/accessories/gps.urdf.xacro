<?xml version="1.0"?>



<robot name="gps_antenna" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:macro name="gps_antenna" params="prefix parent *origin">



    <!-- Electrical Box -->
    <link name="${prefix}gps_antenna_link" >
      <!-- <visual>
        <origin xyz="0 0 0.0278" rpy="0 0 0" />
        <geometry>
            <cylinder radius="0.01375" length="0.0556"/>
