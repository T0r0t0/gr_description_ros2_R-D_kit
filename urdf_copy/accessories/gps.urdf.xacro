          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>
      <collision>
      <origin xyz="0 0 0.0278" rpy="0 0 0" />
         <geometry>
            <cylinder radius="0.01375" length="0.0556"/>
